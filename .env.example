# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

# -------------------------------
# DATABASE (USE A PUBLIC URL)
# -------------------------------
MYSQL_URL=${{MYSQL_PUBLIC_URL}}

# fallback (opcional)
MYSQLHOST=${{RAILWAY_TCP_PROXY_DOMAIN}}
MYSQLPORT=${{RAILWAY_TCP_PROXY_PORT}}
MYSQLUSER=root
MYSQLPASSWORD=${{MYSQL_ROOT_PASSWORD}}
MYSQL_DATABASE=railway

# .NET connection string (RECOMENDADO)
ConnectionStrings__MySQL=server=${{RAILWAY_TCP_PROXY_DOMAIN}};port=${{RAILWAY_TCP_PROXY_PORT}};database=railway;user=root;password=${{MYSQL_ROOT_PASSWORD}}

# -------------------------------
# STARTUP
# -------------------------------
SEED_ON_STARTUP=false
APPLY_MIGRATIONS_ON_STARTUP=true

# -------------------------------
# CORS (IMPORTANTE)
# -------------------------------
CORS_ALLOWED_ORIGINS=https://liontto.vercel.app,https://liontto-git-master-codifys-projects-07a7789e.vercel.app

# -------------------------------
# FRONTEND -> BACKEND
# -------------------------------
BACKEND_ORIGIN=https://SEU-BACKEND.up.railway.app