# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000

# Database
DB_CONNECTION=Server=127.0.0.1;Port=3306;Database=liontto;User=CHANGE_ME;Password=CHANGE_ME;CharSet=utf8mb4;

