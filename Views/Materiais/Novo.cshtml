@* Views/Materiais/Novo.cshtml *@
@model Material
@{ ViewData["Title"] = "Novo Material"; }

<div class="card" style="max-width:600px;">
    <form method="post" action="/Materiais/Novo">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group" style="grid-column:1/-1;">
                <label>Nome do Material *</label>
                <input type="text" name="Nome" value="@Model?.Nome" placeholder="Ex: MDF 15mm Branco" required/>
            </div>
            <div class="form-group">
                <label>Unidade de Medida *</label>
                <select name="Unidade" required>
                    <option value="">Selecione...</option>
                    @foreach (var u in new[]{"m²","metro","unidade","par","kg","litro","caixa","rolo"})
                    {
                        @* CORREÇÃO: if separado para evitar RZ1031 — Razor não aceita ternário em atributos *@
                        if (Model?.Unidade == u)
                        {
                            <option value="@u" selected>@u</option>
                        }
                        else
                        {
                            <option value="@u">@u</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Quantidade Inicial</label>
                <input type="number" name="Quantidade" value="@(Model?.Quantidade ?? 0)" min="0" step="0.01"/>
            </div>
            <div class="form-group">
                <label>Quantidade Mínima (Alerta)</label>
                <input type="number" name="QuantidadeMinima" value="@(Model?.QuantidadeMinima ?? 5)" min="0" step="0.01"/>
                <span class="text-muted" style="font-size:12px;margin-top:4px;display:block;">
                    Alerta quando o estoque cair abaixo deste valor
                </span>
            </div>
            <div class="form-group">
                <label>Preço Unitário (R$)</label>
                <input type="number" name="PrecoUnitario" value="@(Model?.PrecoUnitario ?? 0)" min="0" step="0.01"/>
            </div>
        </div>
        <div class="divider"></div>
        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary">💾 Cadastrar Material</button>
            <a href="/Materiais" class="btn btn-outline">Cancelar</a>
        </div>
    </form>
</div>
