@* Views/Materiais/Editar.cshtml *@
@model Material
@{ ViewData["Title"] = "Editar Material"; }

<div class="card" style="max-width:600px;">
    <form method="post" action="/Materiais/Editar/@Model.Id">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group" style="grid-column:1/-1;">
                <label>Nome do Material *</label>
                <input type="text" name="Nome" value="@Model.Nome" required/>
            </div>
            <div class="form-group">
                <label>Unidade de Medida *</label>
                <select name="Unidade" required>
                    @* CORREÇÃO: if separado — Razor Tag Helper não aceita ternário em atributos *@
                    @foreach (var u in new[]{"m²","metro","unidade","par","kg","litro","caixa","rolo"})
                    {
                        if (Model.Unidade == u)
                        {
                            <option value="@u" selected>@u</option>
                        }
                        else
                        {
                            <option value="@u">@u</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Quantidade Mínima</label>
                <input type="number" name="QuantidadeMinima" value="@Model.QuantidadeMinima" min="0" step="0.01"/>
            </div>
            <div class="form-group">
                <label>Preço Unitário (R$)</label>
                <input type="number" name="PrecoUnitario" value="@Model.PrecoUnitario" min="0" step="0.01"/>
            </div>
        </div>
        <input type="hidden" name="Quantidade" value="@Model.Quantidade"/>
        <input type="hidden" name="CriadoEm"   value="@Model.CriadoEm.ToString("o")"/>
        <div class="divider"></div>
        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary">💾 Salvar Alterações</button>
            <a href="/Materiais" class="btn btn-outline">Cancelar</a>
        </div>
    </form>
</div>
