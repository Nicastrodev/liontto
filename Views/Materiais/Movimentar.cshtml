@* Views/Materiais/Movimentar.cshtml *@
@model MovimentacaoViewModel
@{ ViewData["Title"] = "Movimentar Estoque"; }

<div class="two-col">
    <div class="card">
        <div class="mb-4">
            <div class="text-muted" style="font-size:13px;margin-bottom:4px;">Material</div>
            <div style="font-size:20px;font-weight:700;color:var(--primary);">@Model.Material.Nome</div>
            <div class="stat-card mt-3" style="padding:14px;">
                <div class="stat-icon brown">📦</div>
                <div>
                    <div class="stat-value" style="font-size:22px;">@Model.Material.Quantidade</div>
                    <div class="stat-label">@Model.Material.Unidade em estoque</div>
                </div>
            </div>
        </div>
        <div class="divider"></div>
        <form method="post" action="/Materiais/Movimentar/@Model.Material.Id">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Tipo de Movimentação *</label>
                <div class="flex gap-3" style="margin-top:6px;">
                    <label style="cursor:pointer;display:flex;align-items:center;gap:8px;">
                        <input type="radio" name="Tipo" value="Entrada" checked style="width:auto;"/> 📥 Entrada
                    </label>
                    <label style="cursor:pointer;display:flex;align-items:center;gap:8px;">
                        <input type="radio" name="Tipo" value="Saida" style="width:auto;"/> 📤 Saída
                    </label>
                </div>
            </div>
            <div class="form-group">
                <label>Quantidade (@Model.Material.Unidade) *</label>
                <input type="number" name="Quantidade" min="0.01" step="0.01" required placeholder="Ex: 10"/>
            </div>
            <div class="form-group">
                <label>Motivo / Observação</label>
                <textarea name="Motivo" placeholder="Ex: Compra NF 1234 / Uso na produção"></textarea>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="btn btn-primary">✅ Registrar</button>
                <a href="/Materiais" class="btn btn-outline">Voltar</a>
            </div>
        </form>
    </div>

    <div class="card">
        <span class="card-title">Histórico Recente</span>
        @if (Model.Historico.Any())
        {
            <div class="table-wrapper">
                <table>
                    <thead><tr><th>Data</th><th>Tipo</th><th>Qtd.</th><th>Motivo</th></tr></thead>
                    <tbody>
                        @foreach (var h in Model.Historico)
                        {
                            <tr>
                                <td class="text-muted" style="font-size:12px;">@h.DataMovimentacao.ToString("dd/MM/yy HH:mm")</td>
                                <td>
                                    @if (h.Tipo == TipoMovimentacao.Entrada)
                                    { <span class="badge badge-ok">📥 Entrada</span> }
                                    else
                                    { <span class="badge badge-warning">📤 Saída</span> }
                                </td>
                                <td class="fw-600">@h.Quantidade</td>
                                <td class="text-muted" style="font-size:12px;">@(string.IsNullOrEmpty(h.Motivo) ? "—" : h.Motivo)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state" style="padding:30px;">
                <div class="icon">📋</div><p>Nenhuma movimentação registrada.</p>
            </div>
        }
    </div>
</div>
