@* Views/Clientes/Editar.cshtml *@
@model Cliente
@{ ViewData["Title"] = "Editar Cliente"; }

<div class="card" style="max-width:620px;">
    <form method="post" action="/Clientes/Editar/@Model.Id">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group" style="grid-column:1/-1;">
                <label>Nome Completo *</label>
                <input type="text" name="Nome" value="@Model.Nome" required/>
            </div>
            <div class="form-group">
                <label>Telefone</label>
                <input type="text" name="Telefone" value="@Model.Telefone"/>
            </div>
            <div class="form-group">
                <label>E-mail</label>
                <input type="email" name="Email" value="@Model.Email"/>
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label>Endereço</label>
                <input type="text" name="Endereco" value="@Model.Endereco"/>
            </div>
        </div>
        <input type="hidden" name="CriadoEm" value="@Model.CriadoEm.ToString("o")"/>
        <div class="divider"></div>
        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary">💾 Salvar</button>
            <a href="/Clientes" class="btn btn-outline">Cancelar</a>
        </div>
    </form>
</div>
